// ═══════════════════════════════════════════════════════════════════════
// ZIELONE WZGÓRZA — Full Database Schema
// Master Plan v5.0 — Unified Reservation System + Multi-Type Resources
// ═══════════════════════════════════════════════════════════════════════
//
// KEY ARCHITECTURAL DECISIONS (v5.0):
//   1. ResourceCategoryType: ONLY 3 types (ACCOMMODATION / TIME_SLOT / QUANTITY_TIME)
//   2. ReservationItem replaces ReservationResource (startAt/endAt per item)
//   3. TimelineEntry: DateTime everywhere (no @db.Date), quantityReserved for QUANTITY_TIME
//   4. ReservationStatus: added FINISHED + NO_SHOW
//   5. ClientAccount = auth model (old stats → ClientStats)
//   6. Property model + propertyId on core models
//   7. PaymentSchedule for installments
//   8. Partial exclusion constraint: WHERE categoryType != QUANTITY_TIME
//   9. One POST /api/reservations with items[] — atomic creation
//  10. Addons: reservationId (required) + reservationItemId (optional)
//
// ═══════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════
// SYSTEM — Users, Sessions, Roles, Settings, Audit, Property
// ═══════════════════════════════════════════════════════════════════════

model Property {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  postalCode String?
  country   String   @default("PL")
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  settings  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resources    Resource[]
  reservations Reservation[]
  ratePlans    RatePlan[]
  seasons      Season[]
  @@map("properties")
}

// ── D0: User roles ──
enum UserRole {
  OWNER
  MANAGER
  RECEPTION
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole @default(OWNER)
  avatar            String?
  phone             String?
  isActive          Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  lastLoginAt       DateTime?  // renamed from lastLogin (D0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sessions          Session[]
  auditLogs         AuditLog[]
  reservationNotes  ReservationNote[]
  clientNotes       ClientNote[]
  assignedClients   Client[]          @relation("ClientAssignee")
  assignedReservations Reservation[]  @relation("ReservationAssignee")
  paymentsCreated   Payment[]       @relation("PaymentCreatedBy")
  paymentsConfirmed Payment[]       @relation("PaymentConfirmedBy")
  paymentsRejected  Payment[]       @relation("PaymentRejectedBy")
  cleaningTasks     CleaningTask[]    @relation("CleaningAssignee")
  operationalTasks  OperationalTask[] @relation("TaskAssignee")
  emailTemplatesUpdated EmailTemplate[] @relation("EmailTemplateUpdatedBy")
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model CompanySettings {
  id             String  @id @default("default")
  companyName    String  @default("Zielone Wzgórza")
  legalName      String?
  nip            String?
  regon          String?
  address        String?
  city           String?
  postalCode     String?
  country        String  @default("PL")
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  timezone       String  @default("Europe/Warsaw")
  currency       String  @default("PLN")
  locale         String  @default("pl-PL")
  checkInTime    String  @default("15:00")
  checkOutTime   String  @default("11:00")
  // Reservation settings (frontend client)
  paymentDeadlineHours    Int     @default(24)
  paymentDeadlineAction   String  @default("CANCEL")
  requiredDepositPercent  Int     @default(30)
  minInstallmentAmount    Int     @default(10000)
  overdueNotificationHours Int    @default(12)
  // Payment methods — JSON config per Master Plan 9.8
  // Format: [{ method, isActive, availableForAdmin, availableForWidget,
  //            availableForOnline, requiresConfirmation, displayName, sortOrder }]
  paymentMethodsConfig Json   @default("[]")
  // LEGACY booleans (kept for backward compat, S2b drop)
  paymentBankTransfer Boolean @default(true)
  paymentOnline       Boolean @default(true)
  paymentCash         Boolean @default(true)
  // E3: Email settings (business config — SMTP credentials in .env)
  senderEmail         String?   // adres nadawcy emaili (np. system@zielonewzgorza.eu)
  senderName          String    @default("Zielone Wzgórza")  // nazwa nadawcy
  replyToEmail        String?   // adres do odpowiedzi (jeśli inny niż sender)
  // E3: Bank account for payment instructions
  bankAccountName     String    @default("Grupa Truszkowscy sp. z o.o.")
  bankAccountIban     String    @default("89 1090 1102 0000 0001 5948 7356")
  bankName            String    @default("Santander Bank Polska")
  // E3: Reminder settings
  reminderEnabled     Boolean   @default(true)
  reminderDays        Int       @default(3)   // po ilu dniach PENDING → reminder
  maxReminders        Int       @default(2)   // max reminderów per rezerwację
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@map("company_settings")
}

model TaxConfig {
  id          String   @id @default(cuid())
  name        String
  type        TaxType  @default(PERCENTAGE)
  rate        Decimal
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reservationTaxes ReservationTax[]
  @@map("tax_configs")
}

enum TaxType {
  PERCENTAGE
  FIXED_PER_NIGHT
  FIXED_PER_PERSON
  FIXED_PER_BOOKING
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String
  changes    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE 1 — Resources + Inventory Layer
// ═══════════════════════════════════════════════════════════════════════

model ResourceCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        ResourceCategoryType
  icon        String?
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  // D 159-162: nullable override per category (fallback → CompanySettings)
  checkInTimeOverride  String?  // format "HH:MM", null = use global
  checkOutTimeOverride String?  // format "HH:MM", null = use global
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resources Resource[]
  @@map("resource_categories")
}

enum ResourceCategoryType {
  ACCOMMODATION
  TIME_SLOT
  QUANTITY_TIME
}

model Resource {
  id           String   @id @default(cuid())
  propertyId   String?
  categoryId   String
  name         String
  slug         String   @unique
  unitNumber   String?
  description  String?
  shortDesc    String?
  status       ResourceStatus @default(ACTIVE)
  sortOrder    Int      @default(0)
  maxCapacity    Int?
  totalUnits     Int      @default(1)
  area           Decimal?
  floor          Int?
  location       String?
  unitDuration   Int?
  minPersons     Int?
  maxPersons     Int?
  durationMinutes Int?
  isSeasonal     Boolean  @default(false)
  seasonStart    Int?
  seasonEnd      Int?
  // E2: widget visibility — only ACTIVE + visibleInWidget + ACCOMMODATION shown in public booking
  visibleInWidget Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property            Property?            @relation(fields: [propertyId], references: [id])
  category            ResourceCategory     @relation(fields: [categoryId], references: [id])
  variants            ResourceVariant[]
  images              ResourceImage[]
  amenities           ResourceAmenity[]
  blockedPeriods      BlockedPeriod[]
  reservationItems    ReservationItem[]
  channelMappings     ChannelMapping[]
  availabilityCache   AvailabilityCache[]
  timelineEntries     TimelineEntry[]
  @@index([propertyId])
  @@index([categoryId])
  @@index([status])
  @@map("resources")
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SEASONAL
}

model ResourceVariant {
  id           String   @id @default(cuid())
  resourceId   String
  name         String
  slug         String   @unique
  unitNumber   String?
  description  String?
  capacity     Int
  basePrice    Decimal?       // LEGACY
  basePriceMinor Int?         // grosze — source of truth
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resource     Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  priceEntries PriceEntry[]
  @@index([resourceId])
  @@map("resource_variants")
}

model ResourceImage {
  id           String   @id @default(cuid())
  resourceId   String
  storageKey   String   @unique   // properties/{propId}/resources/{resId}/original/{uuid}.webp
  thumbnailKey String              // .../thumbnail/{uuid}.webp
  mediumKey    String              // .../medium/{uuid}.webp
  mimeType     String              // image/webp (po konwersji)
  width        Int                 // original px
  height       Int                 // original px
  sizeBytes    Int                 // original file size
  checksum     String              // SHA-256 of original upload
  alt          String?             // alt text dla accessibility
  position     Int                 // kolejność wyświetlania (0-based)
  isCover      Boolean  @default(false)  // okładka zasobu — partial unique index w raw SQL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  @@unique([resourceId, position])
  @@index([resourceId])
  @@map("resource_images")
}

model ResourceAmenity {
  id         String   @id @default(cuid())
  resourceId String
  name       String
  icon       String?
  createdAt  DateTime @default(now())
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  @@index([resourceId])
  @@map("resource_amenities")
}

model Addon {
  id           String         @id @default(cuid())
  name         String
  description  String?
  scope        AddonScope     @default(GLOBAL)
  pricingType  AddonPricingType
  price        Decimal       // LEGACY
  priceMinor   Int           @default(0)  // grosze — source of truth
  selectType   AddonSelectType @default(CHECKBOX)
  isRequired   Boolean        @default(false)
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  reservationAddons ReservationAddon[]
  @@index([scope, isActive])
  @@map("addons")
}

enum AddonScope {
  GLOBAL
  PER_ITEM
}

enum AddonPricingType {
  PER_BOOKING
  PER_NIGHT
  PER_PERSON
  PER_PERSON_NIGHT
  PER_UNIT
}

enum AddonSelectType {
  CHECKBOX
  QUANTITY
  SELECT
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE 2 — Pricing System
// ═══════════════════════════════════════════════════════════════════════

model Season {
  id         String   @id @default(cuid())
  propertyId String?
  name       String
  type       String   @default("standard")
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  color      String?
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property     Property?    @relation(fields: [propertyId], references: [id])
  priceEntries PriceEntry[]
  @@index([propertyId])
  @@map("seasons")
}

model RatePlan {
  id            String    @id @default(cuid())
  propertyId    String?
  name          String
  slug          String    @unique
  description   String?
  isActive      Boolean   @default(true)
  isDefault     Boolean   @default(false)
  sortOrder     Int       @default(0)
  parentId      String?
  modifierType  RatePlanModifier?
  modifierValue Decimal?          // LEGACY (for FIXED = PLN, for PERCENTAGE = %)
  modifierValueMinor Int?         // grosze — source of truth gdy FIXED
  cancellationPolicy CancellationPolicy @default(FLEXIBLE)
  cancellationDays   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  property      Property?  @relation(fields: [propertyId], references: [id])
  parent        RatePlan?  @relation("RatePlanInheritance", fields: [parentId], references: [id])
  children      RatePlan[] @relation("RatePlanInheritance")
  priceEntries  PriceEntry[]
  @@index([propertyId])
  @@map("rate_plans")
}

enum RatePlanModifier {
  PERCENTAGE
  FIXED
}
enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
  SUPER_STRICT
}

model PriceEntry {
  id         String   @id @default(cuid())
  variantId  String
  ratePlanId String
  seasonId   String?
  date       DateTime? @db.Date
  price      Decimal       // LEGACY
  priceMinor Int      @default(0)  // grosze — source of truth
  currency   String   @default("PLN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  variant  ResourceVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  ratePlan RatePlan        @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  season   Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  @@unique([variantId, ratePlanId, date])
  @@index([variantId, ratePlanId])
  @@index([date])
  @@map("price_entries")
}

model PriceRule {
  id          String        @id @default(cuid())
  name        String
  type        PriceRuleType
  value       Decimal
  minPersons  Int?
  maxPersons  Int?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@map("price_rules")
}

enum PriceRuleType {
  PER_ADULT
  PER_CHILD
  PER_INFANT
  PER_HOUR
  PER_DAY
  PER_GROUP
}

model Restriction {
  id                String   @id @default(cuid())
  name              String
  startDate         DateTime @db.Date
  endDate           DateTime @db.Date
  minNights         Int?
  maxNights         Int?
  allowedArrivalDays   String?
  allowedDepartureDays String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@map("restrictions")
}

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  discountType   DiscountType
  discountValue  Decimal       // LEGACY
  discountValueMinor Int       @default(0)  // grosze — source of truth
  minBookingValue Decimal?     // LEGACY
  minBookingValueMinor Int?    // grosze — source of truth
  maxUses        Int?
  usedCount      Int       @default(0)
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reservations Reservation[]
  @@map("promo_codes")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE 3 — Calendar + Timeline (Source of Truth for Availability)
// ═══════════════════════════════════════════════════════════════════════

model BlockedPeriod {
  id         String     @id @default(cuid())
  resourceId String
  reason     BlockReason
  note       String?
  startDate  DateTime   @db.Date
  endDate    DateTime   @db.Date
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  @@index([resourceId, startDate, endDate])
  @@map("blocked_periods")
}

enum BlockReason {
  CAMP
  MAINTENANCE
  OWNER_USE
  EXTERNAL
  OTHER
}

model AvailabilityCache {
  id           String   @id @default(cuid())
  resourceId   String
  date         DateTime @db.Date
  totalUnits   Int
  bookedUnits  Int      @default(0)
  blockedUnits Int      @default(0)
  availableUnits Int    @default(0)
  minPrice     Decimal?
  updatedAt    DateTime @updatedAt
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  @@unique([resourceId, date])
  @@index([date])
  @@index([resourceId, date])
  @@map("availability_cache")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean  @default(false)
  color       String?
  type        CalendarEventType @default(INTERNAL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([startDate, endDate])
  @@map("calendar_events")
}

enum CalendarEventType {
  INTERNAL
  PUBLIC
  HOLIDAY
  MAINTENANCE
}

model TimelineEntry {
  id                  String              @id @default(cuid())
  type                TimelineEntryType
  status              TimelineEntryStatus @default(ACTIVE)
  resourceId          String
  startAt             DateTime
  endAt               DateTime
  quantityReserved    Int                 @default(1)
  label               String?
  note                String?
  reservationId       String?
  reservationItemId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  resource        Resource         @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  reservation     Reservation?     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationItem ReservationItem? @relation(fields: [reservationItemId], references: [id], onDelete: Cascade)
  @@index([resourceId, startAt, endAt])
  @@index([type, status])
  @@index([reservationId])
  @@index([reservationItemId])
  @@map("timeline_entries")
}

enum TimelineEntryType {
  BOOKING
  BLOCK
  OFFER
}
enum TimelineEntryStatus {
  ACTIVE
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE 4 — Unified Reservation System (v5.0)
// ═══════════════════════════════════════════════════════════════════════

model Reservation {
  id                  String              @id @default(cuid())
  number              String              @unique
  type                ReservationType
  status              ReservationStatus   @default(PENDING)
  propertyId          String?
  requiresAttention   Boolean             @default(false)
  requiresAttentionReason String?
  paymentStatus       ResPaymentStatus    @default(UNPAID)
  overdue             Boolean             @default(false)
  clientId            String?
  assignedUserId      String?
  source              ReservationSource   @default(PHONE)
  checkIn             DateTime
  checkOut            DateTime
  nights              Int
  adults              Int                 @default(1)
  children            Int                 @default(0)
  subtotal            Decimal             @default(0)  // LEGACY (read-only po C1a)
  discount            Decimal             @default(0)  // LEGACY
  total               Decimal             @default(0)  // LEGACY
  subtotalMinor       Int                 @default(0)  // grosze — source of truth
  discountMinor       Int                 @default(0)  // grosze — source of truth
  totalMinor          Int                 @default(0)  // grosze — source of truth
  requiredDepositMinor Int                @default(0)  // grosze — snapshot progu (9.7)
  requiredDepositRuleSnapshot Json?                    // snapshot reguły depozytu z CompanySettings (audyt)
  currency            String              @default("PLN")
  guestNotes          String?
  internalNotes       String?
  promoCodeId         String?
  cancelledAt         DateTime?
  cancelReason        String?
  cancelledBy         String?
  paymentDeadlineAt   DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  property            Property?           @relation(fields: [propertyId], references: [id])
  client              Client?             @relation(fields: [clientId], references: [id])
  assignedUser        User?               @relation("ReservationAssignee", fields: [assignedUserId], references: [id])
  promoCode           PromoCode?          @relation(fields: [promoCodeId], references: [id])
  items               ReservationItem[]
  addons              ReservationAddon[]
  statusLogs          ReservationStatusLog[]
  notes               ReservationNote[]
  timelineEntries     TimelineEntry[]
  offerDetails        OfferDetails?
  bookingDetails      BookingDetails?
  payments            Payment[]
  paymentSchedules    PaymentSchedule[]
  invoices            Invoice[]
  deposits            Deposit[]
  priceSnapshot       ReservationPriceSnapshot?
  taxes               ReservationTax[]
  guests              ReservationGuest[]
  cleaningTasks       CleaningTask[]
  messageLogs         MessageLog[]
  quotes              Quote[]
  emailLogs           EmailLog[]
  @@index([propertyId])
  @@index([clientId])
  @@index([assignedUserId])
  @@index([type, status])
  @@index([checkIn, checkOut])
  @@index([number])
  @@index([source])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([overdue])
  @@map("reservations")
}

enum ReservationType {
  BOOKING
  OFFER
  BLOCK
}
enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  FINISHED
  NO_SHOW
}
enum ResPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}
enum ReservationSource {
  PHONE
  EMAIL
  WEBSITE
  WALK_IN
  BOOKING_COM
  SOCIAL
  FRONT
  OTHER
}

model ReservationItem {
  id                String              @id @default(cuid())
  reservationId     String
  resourceId        String
  categoryType      ResourceCategoryType
  startAt           DateTime
  endAt             DateTime
  quantity          Int                 @default(1)
  pricePerUnit      Decimal             @default(0)  // LEGACY
  totalPrice        Decimal             @default(0)  // LEGACY
  pricePerUnitMinor Int                 @default(0)  // grosze — source of truth
  totalPriceMinor   Int                 @default(0)  // grosze — source of truth
  adults            Int                 @default(1)
  children          Int                 @default(0)
  capacityOverride  Boolean             @default(false)
  priceSnapshot     Json?
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  reservation       Reservation         @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  resource          Resource            @relation(fields: [resourceId], references: [id])
  timelineEntries   TimelineEntry[]
  addons            ReservationAddon[]
  @@index([reservationId])
  @@index([resourceId])
  @@index([categoryType])
  @@map("reservation_items")
}

model OfferDetails {
  id            String    @id @default(cuid())
  reservationId String    @unique
  token         String    @unique
  pin           String?
  expiresAt     DateTime?
  expiryAction  ExpiryAction @default(CANCEL)
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  expiredAt     DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  @@map("offer_details")
}

enum ExpiryAction {
  CANCEL
  NOTHING
}

model BookingDetails {
  id            String    @id @default(cuid())
  reservationId String    @unique
  paidAmount    Decimal   @default(0)  // LEGACY
  balanceDue    Decimal   @default(0)  // LEGACY
  paidAmountMinor Int     @default(0)  // grosze — source of truth
  balanceDueMinor Int     @default(0)  // grosze — source of truth
  overpaidAmountMinor Int @default(0)  // grosze — max(paidAmountMinor - totalMinor, 0)
  confirmedAt   DateTime?
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  token         String?   @unique
  // E2: RODO consent log for public booking
  consentAcceptedAt   DateTime?
  consentTermsVersion String?
  consentIpAddress    String?
  consentUserAgent    String?
  // E3: Payment reminder tracking (idempotency)
  paymentReminderCount    Int       @default(0)
  lastPaymentReminderAt   DateTime?
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  @@map("booking_details")
}

// ── E3: Email audit trail ──

enum EmailLogType {
  BOOKING_CONFIRMATION
  PAYMENT_REMINDER
  STATUS_CONFIRMED
  STATUS_CANCELLED
  TEST
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

