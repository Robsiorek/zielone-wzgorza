  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  @@unique([channelId, resourceId])
  @@map("channel_mappings")
}

model ChannelSyncLog {
  id         String         @id @default(cuid())
  channelId  String
  direction  SyncDirection
  type       String
  status     SyncStatus
  details    Json?
  error      String?
  createdAt  DateTime       @default(now())
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  @@index([channelId])
  @@index([createdAt])
  @@map("channel_sync_logs")
}

enum SyncDirection {
  PUSH
  PULL
}
enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
}

// ═══════════════════════════════════════════════════════════════════════
// MODULE 12 — Webhook System
// ═══════════════════════════════════════════════════════════════════════

model Webhook {
  id          String   @id @default(cuid())
  name        String
  url         String
  secret      String?
  events      String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  logs WebhookLog[]
  @@map("webhooks")
}

model WebhookLog {
  id          String          @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?
  status      WebhookLogStatus @default(PENDING)
  attempts    Int             @default(0)
  nextRetryAt DateTime?
  createdAt   DateTime        @default(now())
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_logs")
}

enum WebhookLogStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}
