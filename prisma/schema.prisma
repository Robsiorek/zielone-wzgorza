// ═══════════════════════════════════════════════════════════════════════
// MODULE 7 — Payments / Finance (immutable ledger + corrections only)
// C1b: Full Payment model per Master Plan 9.2
// ═══════════════════════════════════════════════════════════════════════

model Payment {
  id                String              @id @default(cuid())
  reservationId     String

  // ── C1b: New fields (source of truth) ──
  kind              PaymentKind?        // CHARGE / REFUND / ADJUSTMENT
  direction         PaymentDirection?   // IN (inflow) / OUT (outflow)
  paymentStatus     PaymentStatus?      // PENDING / CONFIRMED / REJECTED / FAILED / CANCELLED

  // ── C1b: Actor fields ──
  createdByUserId   String?
  createdSource     PaymentSource?      @default(ADMIN_MANUAL)
  confirmedByUserId String?
  confirmedAt       DateTime?
  rejectedByUserId  String?
  rejectedAt        DateTime?
  rejectionReason   String?

  // ── C1b: Financial ──
  amountMinor       Int                 @default(0)  // grosze — source of truth
  amount            Decimal             // LEGACY (read-only po C1a)
  currency          String              @default("PLN")
  method            PaymentMethod

  // ── C1b: Dates & references ──
  occurredAt        DateTime?           // kiedy operacja realnie zaszła
  referenceNumber   String?             // nr przelewu / ID transakcji

  // ── C1b: Linking & idempotency ──
  linkedPaymentId   String?             // referencja do powiązanej płatności (refund → charge)
  externalCorrelationId String?         // idempotency key / integracje

  // ── C1b: Online payment provider (nullable, przyszłość) ──
  provider          String?
  providerPaymentId String?
  webhookEventId    String?

  // Legacy columns dropped in S2b (01.04.2026)

  // ── Common ──
  note              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // ── Relations ──
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  createdByUser   User?       @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id])
  confirmedByUser User?       @relation("PaymentConfirmedBy", fields: [confirmedByUserId], references: [id])
  rejectedByUser  User?       @relation("PaymentRejectedBy", fields: [rejectedByUserId], references: [id])
  linkedPayment   Payment?    @relation("PaymentLink", fields: [linkedPaymentId], references: [id])
  linkedPayments  Payment[]   @relation("PaymentLink")
  @@index([reservationId])
  @@index([paymentStatus])
  @@map("payments")
}

// ── C1b: New enums ──
enum PaymentKind {
  CHARGE
  REFUND
  ADJUSTMENT
}
enum PaymentDirection {
  IN
  OUT
}
enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  FAILED
  CANCELLED
}
enum PaymentSource {
  ADMIN_MANUAL
  SYSTEM
  WEBHOOK
  IMPORT
}

// Legacy enums PaymentType + PaymentConfirmStatus dropped in S2b (01.04.2026)
enum PaymentMethod {
  BANK_TRANSFER  // LEGACY — backfilled to TRANSFER
  CASH
  CARD
  ONLINE
  OTHER
  TRANSFER
  TERMINAL
  BLIK
}

model PaymentSchedule {
  id            String                @id @default(cuid())
  reservationId String
  amount        Decimal
  dueDate       DateTime
  status        PaymentScheduleStatus @default(PENDING)
  paidAt        DateTime?
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  @@index([reservationId])
  @@index([dueDate])
  @@index([status])
  @@map("payment_schedules")
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
}

model Deposit {
  id            String        @id @default(cuid())
  reservationId String
  amount        Decimal
  currency      String        @default("PLN")
  status        DepositStatus @default(HELD)
  collectedAt   DateTime?
  returnedAt    DateTime?
