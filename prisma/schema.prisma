  @@index([reservationId])
  @@map("deposits")
}

enum DepositStatus {
  HELD
  PARTIALLY_RETURNED
  RETURNED
  FORFEITED
}

// ── E1: Quote (price quote with expiry, single-use, anti-enumeration) ──
model Quote {
  id            String    @id @default(cuid())
  secret        String    // 32-char hex, required for booking (anti-enumeration)
  payload       Json      // canonical input: { checkIn, checkOut, items, addons, promoCode }
  payloadHash   String    // sha256(canonicalJson(payload)) for verification
  result        Json      // full quote result (exactly what client sees)
  totalMinor    Int       // denormalized for quick lookups
  expiresAt     DateTime  // quote validity window
  usedAt        DateTime? // null = unused, set when booking created
  reservationId String?   // FK to reservation created from this quote
  createdAt     DateTime  @default(now())
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  @@index([expiresAt])
  @@index([payloadHash])
  @@map("quotes")
}

model Invoice {
  id            String   @id @default(cuid())
  reservationId String
  invoiceNumber String   @unique
  type          InvoiceType @default(INVOICE)
  issueDate     DateTime @db.Date
  dueDate       DateTime? @db.Date
  netAmount     Decimal
