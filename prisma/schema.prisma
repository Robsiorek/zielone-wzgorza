  currency      String   @default("PLN")
  status        InvoiceStatus @default(DRAFT)
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reservation Reservation @relation(fields: [reservationId], references: [id])
  @@index([reservationId])
  @@map("invoices")
}

enum InvoiceType {
  INVOICE
  PROFORMA
  RECEIPT
  CREDIT_NOTE
}
enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

