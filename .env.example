# ═══════════════════════════════════════════════════════════════
# Zielone Wzgórza — Panel Administracyjny
# Plik konfiguracji środowiska
# Skopiuj do .env i uzupełnij wartości
# ═══════════════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/zielone_wzgorza_admin"

# ── Auth ──
# WYMAGANE — aplikacja nie wystartuje bez tego klucza.
# Wygeneruj: openssl rand -hex 32
JWT_SECRET=""

# ── URL Configuration ──
# Wszystkie URL-e w systemie budowane z tych zmiennych.
# Zmiana domeny = zmiana tutaj, zero zmian w kodzie.
NEXT_PUBLIC_ADMIN_BASE_URL="https://dev.zielonewzgorza.eu/admin"
NEXT_PUBLIC_ENGINE_BASE_URL="https://dev.zielonewzgorza.eu"
NEXT_PUBLIC_API_BASE_URL="https://dev.zielonewzgorza.eu/admin"
NEXT_PUBLIC_FRONT_BASE_URL="https://zielonewzgorza.eu"

# ── SMTP (Email) ──
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD=""
# EMAIL_DRY_RUN="true"  — odkomentuj żeby logować emaile bez wysyłania

# ── Cron / Internal API ──
# Klucz autoryzujący wewnętrzne endpointy (/api/internal/*)
CRON_SECRET=""

# ── Media Storage (B1) ──
# "local" = filesystem (dev), "r2" = Cloudflare R2 (produkcja)
STORAGE_PROVIDER="local"
LOCAL_MEDIA_DIR="data/media"

# ── Cloudflare R2 (tylko gdy STORAGE_PROVIDER=r2) ──
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_DOMAIN=""
