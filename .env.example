# ═══════════════════════════════════════════════════════════════
# Zielone Wzgórza — Environment Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zielone_wzgorza_admin"

# JWT Auth
JWT_SECRET="your-secret-key-here"

# ── URL Configuration ──
# All URLs in the system are built from these variables.
# Change domain/subdomain here — zero code changes needed.

# Admin panel (Next.js basePath = /admin)
NEXT_PUBLIC_ADMIN_BASE_URL="https://dev.zielonewzgorza.eu/admin"

# Public engine (offer view, booking confirmation, payment)
NEXT_PUBLIC_ENGINE_BASE_URL="https://dev.zielonewzgorza.eu"

# API root (same as admin for now, separate later)
NEXT_PUBLIC_API_BASE_URL="https://dev.zielonewzgorza.eu/admin"

# Marketing front (WordPress)
NEXT_PUBLIC_FRONT_BASE_URL="https://zielonewzgorza.eu"
