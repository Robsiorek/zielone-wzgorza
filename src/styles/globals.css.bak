@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 0 0% 100%;
    --foreground: 220 15% 12%;
    --card: 0 0% 100%;
    --card-foreground: 220 15% 12%;
    --primary: 214 89% 52%;
    --primary-foreground: 0 0% 100%;
    --secondary: 220 14% 96%;
    --secondary-foreground: 220 14% 30%;
    --muted: 220 12% 96%;
    --muted-foreground: 220 8% 52%;
    --accent: 214 80% 96%;
    --accent-foreground: 214 89% 42%;
    --destructive: 0 72% 51%;
    --destructive-foreground: 0 0% 100%;
    --border: 220 13% 90%;
    --input: 220 13% 90%;
    --ring: 214 89% 52%;
    --radius: 14px;
  }
  .dark {
    --background: 220 20% 7%;
    --foreground: 210 20% 93%;
    --card: 220 18% 10%;
    --card-foreground: 210 20% 93%;
    --primary: 214 89% 58%;
    --primary-foreground: 0 0% 100%;
    --secondary: 220 16% 14%;
    --secondary-foreground: 210 16% 82%;
    --muted: 220 16% 12%;
    --muted-foreground: 220 10% 52%;
    --accent: 214 40% 16%;
    --accent-foreground: 214 80% 72%;
    --destructive: 0 62% 50%;
    --destructive-foreground: 0 0% 100%;
    --border: 220 16% 18%;
    --input: 220 16% 18%;
    --ring: 214 89% 58%;
  }
}

@layer base {
  * { @apply border-border; }
  body { @apply bg-background text-foreground antialiased; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { @apply rounded-full; background: hsl(var(--border)); }
}

@layer utilities {
  .bubble { @apply rounded-2xl border bg-card transition-all duration-200; }
  .bubble:hover { border-color: hsl(var(--primary) / 0.2); }
  .bubble-sm { @apply rounded-xl border bg-card; }
  .slide-in { animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .slide-in-left { animation: slideInLeft 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
  .fade-in { animation: fadeIn 0.2s ease-out; }
  .scale-in { animation: scaleIn 0.2s cubic-bezier(0.16, 1, 0.3, 1); }
}

@keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
@keyframes slideInLeft { from { transform: translateX(-100%); } to { transform: translateX(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes scaleIn { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }
